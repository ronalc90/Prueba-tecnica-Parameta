{
	"info": {
		"name": "Parameta - Servicio Empleados",
		"description": "Coleccion de pruebas para el servicio REST de empleados.\n\nBase URL: http://localhost:8080",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		}
	],
	"item": [
		{
			"name": "Caso feliz — Registrar empleado valido",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/empleados?nombres=Ronald&apellidos=Cipagauta&tipoDocumento=CC&numeroDocumento=1023456789&fechaNacimiento=1990-05-10&fechaVinculacion=2020-01-15&cargo=Backend Developer&salario=5000000",
					"host": ["{{baseUrl}}"],
					"path": ["api", "empleados"],
					"query": [
						{ "key": "nombres", "value": "Ronald" },
						{ "key": "apellidos", "value": "Cipagauta" },
						{ "key": "tipoDocumento", "value": "CC" },
						{ "key": "numeroDocumento", "value": "1023456789" },
						{ "key": "fechaNacimiento", "value": "1990-05-10" },
						{ "key": "fechaVinculacion", "value": "2020-01-15" },
						{ "key": "cargo", "value": "Backend Developer" },
						{ "key": "salario", "value": "5000000" }
					]
				},
				"description": "Registra un empleado mayor de edad con todos los campos validos.\n\nEsperado: 200 OK con edad y tiempoVinculacion calculados."
			},
			"response": []
		},
		{
			"name": "Error — Menor de edad",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/empleados?nombres=Juan&apellidos=Perez&tipoDocumento=TI&numeroDocumento=999888&fechaNacimiento=2015-06-20&fechaVinculacion=2024-01-01&cargo=Becario&salario=1000000",
					"host": ["{{baseUrl}}"],
					"path": ["api", "empleados"],
					"query": [
						{ "key": "nombres", "value": "Juan" },
						{ "key": "apellidos", "value": "Perez" },
						{ "key": "tipoDocumento", "value": "TI" },
						{ "key": "numeroDocumento", "value": "999888" },
						{ "key": "fechaNacimiento", "value": "2015-06-20" },
						{ "key": "fechaVinculacion", "value": "2024-01-01" },
						{ "key": "cargo", "value": "Becario" },
						{ "key": "salario", "value": "1000000" }
					]
				},
				"description": "Intenta registrar un empleado menor de 18 anios.\n\nEsperado: 400 Bad Request con mensaje 'El empleado debe ser mayor de edad'."
			},
			"response": []
		},
		{
			"name": "Error — Campos vacios",
			"request": {
				"method": "GET",
				"header": [],
